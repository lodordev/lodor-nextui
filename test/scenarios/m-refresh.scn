# Task #133: the full mirror lives behind its own honestly-labelled row.
# lodor#60: wizard-canon labels — "Refresh library (full)" is the cover-refetching pass
# and must shell --mirror-catalog --full (the update row owns the plain pass).
desc Refresh library (full): catalog --full + collections mirror, saves untouched
config paired
seeded
pick 0|Refresh library (full)
pick 2|
engine 0|RESULT ok
expect_exit 0
expect_trace ENGINE --mirror-catalog --full -> rc=0
expect_trace ENGINE --mirror-collections -> rc=0
expect_trace_absent ENGINE --mirror-catalog -> rc=0
expect_trace_absent ENGINE --push-pending
expect_trace_absent ENGINE --pull-saves
expect_trace PRES timeout=3 msg='Library refreshed'
# LIVE progress (#1): both mirror passes stream through the show2 bridge
expect_trace SHOW2 daemon text='Refreshing your library...'
expect_trace SHOW2 daemon text='Refreshing collections...'
