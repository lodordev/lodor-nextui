# UX #5: an invalid port is never silently discarded — the wizard loops back into the port
# keyboard with the typed value preserved (a two-key edit, not a d-pad retype).
desc invalid port loops back into the keyboard with the typed value preserved
pick 0|Set up now
pick 0|https (secure, recommended)
kb 0|romm.example.com
kb 0|80a0
kb 0|8080
pick 0|Verify TLS certificate (recommended)
engine 0|RESULT server_set=1
kb 2|
expect_exit 0
expect_trace PRES timeout=3 msg='Port must be a number - edit or clear it'
expect_trace KB[Port (leave blank for default)] init='80a0'
expect_trace ENGINE --set-server https://romm.example.com --port 8080 -> rc=0
expect_config_has "root_uri": "https://romm.example.com"
